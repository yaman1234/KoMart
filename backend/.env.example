# ─── Database ─────────────────────────────────────────────────────────────────
# Local:      mongodb://localhost:27017/komart
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/komart?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/komart
MONGO_DB_NAME=komart

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development

# Comma-separated list of allowed frontend origins
# Production example: https://komart.netlify.app,https://komart.com
CORS_ORIGINS=http://localhost:5173

# Serverless (Vercel): skip the full product stock-sync on cold start
# Set to true on Vercel to prevent cold-start timeout
SKIP_STOCK_REFRESH_ON_START=false
